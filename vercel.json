{
  "functions": {
    "server.js": {
      "maxDuration": 30,
      "includeFiles": "newsletter_*.md"
    },
    "api-serverless/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/인물", "destination": "/api-serverless/persons.js" },
    { "source": "/api/배우자", "destination": "/api-serverless/spouses.js" },
    { "source": "/api/부모", "destination": "/api-serverless/parents.js" },
    { "source": "/tiles/(.*)", "destination": "/public/tiles/$1" },
    { "source": "/(.*)", "destination": "/server.js" }
  ]
}
