{
  "functions": {
    "server.js": {
      "maxDuration": 30,
      "includeFiles": "{newsletter_*.md,ads.txt,robots.txt,sitemap.xml,404.html,about.html,guide.html,methodology.html,sources.html,contact.html,privacy.html,terms.html,disclaimer.html,trust.css,src/core/bootstrap.js,public/assets/ui/**}"
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/tiles/(.*)", "destination": "/public/tiles/$1" },
    { "source": "/(.*)", "destination": "/server.js" }
  ]
}
