        <level3 id="ko_014_0060_0010">
            <front>
                <biblioData>
                    <title>
                        <mainTitle>武王封微子於宋,</mainTitle>
                    </title>
                </biblioData>
            </front>
            <text>
                <content>
                    <paragraph align="center">○ <index type="이름">武王</index>封<index type="이름">微子</index>於<index type="국명">宋</index>, <annotation type="원주">
                            <noteContent>『<index type="서명">禮記</index>』 <index type="서명">樂記</index>云, 投<index type="국명">殷</index>之後於<index type="국명">宋</index>, <index type="이름">鄭</index>注, 投, 擧徙之辭也. 時<index type="이름">武王</index>封<index type="이름">紂</index>子<index type="이름">武庚</index>於<index type="지명">殷墟</index>, 所徙者, <index type="이름">微子</index>也. 後<index type="이름">周公</index>更封而大之. 按 『<index type="서명">史記</index>』 <index type="서명">殷本紀</index>云, <index type="이름">周 武王</index>崩, <index type="이름">武庚</index>與<index type="이름">管叔</index>·<index type="이름">蔡叔</index>作亂, <index type="이름">成王</index>命<index type="이름">周公</index>誅之, 而立<index type="이름">微子</index>於<index type="국명">宋</index>, 以續<index type="국명">殷</index>後, <index type="서명">宋世家</index>同.</noteContent>
                        </annotation> 封<index type="이름">箕子</index>於<index type="국명">朝鮮</index>. <annotation type="원주">
                            <noteContent>『<index type="서명">史記</index>』 <index type="서명">宋世家</index>.</noteContent>
                        </annotation>
                    </paragraph>
                </content>
            </text>
        </level3>
    </level2>
    <level2 id="ko_014_0070">
        <front>
            <biblioData>
                <title>
                    <mainTitle>『潛夫論』 卷第九 志氏姓 第三十五</mainTitle>
                </title>
