                    <title>
                        <mainTitle>沙門菩提流志, 勝莊</mainTitle>
                    </title>
                    <subjectClass code="as04_01_02_02" scheme="주제">문화&gt;사상&gt;불교사상&gt;승려(법명·법호)</subjectClass>
