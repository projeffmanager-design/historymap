        <level3 id="ko_016_0030_0010">
            <front>
                <biblioData>
                    <title>
                        <mainTitle>夏·殷之朝適窮, 桀·紂之惡適稔.</mainTitle>
                    </title>
                </biblioData>
            </front>
            <text>
                <content>
                    <paragraph align="center">○ <index type="국명">夏</index>·<index type="국명">殷</index>之朝適窮, <index type="이름">桀</index>·<index type="이름">紂</index>之惡適稔. <index type="국명">商</index>·<index type="국명">周</index>之數適起, <index type="이름">湯</index>·<index type="이름">武</index>之德適<index type="지명">豐</index>. <index type="이름">關龍逢</index>殺, <index type="이름">箕子</index>·<index type="이름">比干</index>囚死, 當<index type="이름">桀</index>·<index type="이름">紂</index>惡盛之時, 亦二子命訖之期也.</paragraph>
                </content>
            </text>
        </level3>
