        <level3 id="ko_061_0120_0010">
            <front>
                <biblioData>
                    <title>
                        <mainTitle>大鑑下第十四世, 東林照覺常總禪師法嗣, 褒親宗諭禪師</mainTitle>
                    </title>
                    <subjectClass code="as04_01_02_02" scheme="주제">문화&gt;사상&gt;불교사상&gt;승려(법명·법호)</subjectClass>
                </biblioData>
            </front>
            <text>
                <content>
                    <paragraph align="center">○ <index type="이름">大鑑</index>下第十四世, <index type="지명">東林</index>
                        <index type="이름">照覺常總禪師</index>法嗣, <index type="지명">褒親</index>
                        <index type="이름">宗諭禪師</index>
                    </paragraph>
                    <paragraph align="center">
                        <pTitle align="center">
                            <index type="지명">東京</index>
                            <index type="지명">褒親</index>
                            <index type="지명">旌德寺</index>
                            <index type="이름">諭禪師</index>
                        </pTitle>, 上堂, <index type="국명">新羅</index>打鼓<index type="국명">大宋</index>. 上堂, 庭前柏子問話, 燈籠露柱著忙.</paragraph>
                </content>
            </text>
        </level3>
    </level2>
