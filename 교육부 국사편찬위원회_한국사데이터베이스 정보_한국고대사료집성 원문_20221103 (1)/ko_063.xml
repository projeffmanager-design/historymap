        <level3 id="ko_063_0010_0010">
            <front>
                <biblioData>
                    <title>
                        <mainTitle>靑龍寺 東塔院 惠果阿闍梨 …… 所傳金剛界法者,</mainTitle>
                    </title>
                    <subjectClass code="as04_01_02_04" scheme="주제">문화&gt;사상&gt;불교사상&gt;사원·단월</subjectClass>
                </biblioData>
            </front>
            <text>
                <content>
                    <paragraph align="center">○ <index type="지명">靑龍寺</index>
                        <index type="지명">東塔院</index>
                        <index type="이름">惠果</index>阿闍梨 …… 所傳<index type="서명">金剛</index>界法者, 則有<index type="지명">大興善寺</index>傳灌頂敎同學<index type="이름">惠應</index>阿闍梨, <index type="이름">惠則</index>, <index type="지명">成都府</index>
                        <index type="이름">惟尙</index>, <index type="지명">汴淋</index>
                        <index type="이름">辨弘</index>. <index type="국명">新羅國</index>僧<index type="이름">惠日</index>, <index type="국명">日本國</index>僧<index type="이름">空海</index>. <index type="지명">靑龍寺</index>
                        <index type="이름">義滿</index>·<index type="이름">義明</index>·<index type="이름">義操</index>·<index type="이름">義照</index>·<index type="이름">義愍</index>·<index type="이름">義政</index>·<index type="이름">義一</index>, 俗居士<index type="이름">靈殷</index>
                        <annotation type="원주">
                            <noteContent>已上十四人, 皆傳授大敎, 次阿闍梨位</noteContent>
                        </annotation>, 次<index type="지명">靑龍寺</index>
                        <index type="지명">東塔院</index>
                        <index type="이름">義操</index>阿闍梨, 所傳金剛界大法, 則有當院同學僧, <index type="이름">法潤</index> …… <index type="지명">會昌寺</index>
                        <index type="국명">新羅國</index>僧<index type="이름">均亮</index> …… 弟子僧<index type="이름">文祕</index>. <annotation type="원주">
                            <noteContent>已上一十四人 授<index type="서명">金剛</index>界大法, 皆次阿闍梨位故</noteContent>
                        </annotation>. </paragraph>
                </content>
            </text>
        </level3>
        <level3 id="ko_063_0010_0020">
            <front>
                <biblioData>
                    <title>
                        <mainTitle>我大興善寺 三藏和尙, 親禮五天, 重諮勝法,</mainTitle>
                    </title>
                    <subjectClass code="as04_01_02_02" scheme="주제">문화&gt;사상&gt;불교사상&gt;승려(법명·법호)</subjectClass>
                </biblioData>
            </front>
            <text>
                <content>
                    <paragraph align="center">○ 我<index type="지명">大興善寺</index>
                        <index type="이름">三藏和尙</index>, 親禮五天, 重諮勝法, 敎流天下, 大法盛傳. 所以<index type="국명">新羅</index>諸國, 經逾數萬, 航海忘軀, 來趨我<index type="국명">唐</index>, 至求勝法. 故得金剛界累代相承, 每年有勅. </paragraph>
                </content>
            </text>
        </level3>
    </level2>
    <level2 id="ko_063_0020">
        <front>
            <biblioData>
                <title>
                    <mainTitle>兩部大法相承師資付法記 卷下</mainTitle>
                </title>
            </biblioData>
        </front>
        <level3 id="ko_063_0020_0010">
            <front>
                <biblioData>
                    <title>
                        <mainTitle>時善無畏三藏, 復將此大毘盧遮那大敎王,</mainTitle>
                    </title>
                    <subjectClass code="as04_01_02_09" scheme="주제">문화&gt;사상&gt;불교사상&gt;불교정책</subjectClass>
                </biblioData>
            </front>
            <text>
                <content>
                    <paragraph align="center">○ 時<index type="이름">善無畏</index>三藏, 復將此<index type="이름">大毘盧遮那</index>大敎王, 傳付<index type="지명">大興善寺</index>沙門一行, 及<index type="지명">保壽寺</index>
                        <index type="국명">新羅國</index>沙門<index type="이름">玄超</index> …… 次沙門<index type="이름">玄超</index>阿闍梨, 復將<index type="이름">大毘盧遮那</index>大敎王, 及蘇悉地敎. 傳付<index type="지명">靑龍寺</index>
                        <index type="지명">東塔院</index>
                        <index type="이름">惠果</index>阿闍梨. 阿闍梨又傳付<index type="지명">成都府</index>僧<index type="이름">惟尙</index>
                        <annotation type="원주">
                            <noteContent>又云<index type="이름">惟明</index>
                            </noteContent>
                        </annotation>, <index type="지명">汴州</index>
                        <index type="이름">辯弘</index>, <index type="국명">新羅國</index>僧<index type="이름">惠日</index>·<index type="이름">悟眞</index>, <index type="국명">日本國</index>
                        <index type="이름">空海</index>, 當院僧<index type="이름">義滿</index> …… <index type="이름">法潤</index>
                        <annotation type="원주">
                            <noteContent>付法傳阿闍梨灌頂位者數, 百十二人</noteContent>
                        </annotation>, 或有在京傳持, 或有外方弘敎.</paragraph>
                </content>
            </text>
        </level3>
    </level2>
