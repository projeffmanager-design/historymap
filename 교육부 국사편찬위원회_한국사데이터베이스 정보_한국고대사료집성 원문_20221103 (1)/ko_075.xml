                    <title>
                        <mainTitle>天台九祖傳 五祖章安尊者</mainTitle>
                    </title>
                    <subjectClass code="as04_01_02_01" scheme="주제">문화&gt;사상&gt;불교사상&gt;경논소</subjectClass>
