        <level3 id="ko_067_0010_0010">
            <front>
                <biblioData>
                    <title>
                        <mainTitle>宋武帝, 朱靈期遇聖僧</mainTitle>
                    </title>
                    <subjectClass code="as04_01_02_09" scheme="주제">문화&gt;사상&gt;불교사상&gt;불교정책</subjectClass>
                </biblioData>
            </front>
            <text>
                <content>
                    <paragraph align="center">○ <index type="이름">宋武帝</index>, <index type="이름">朱靈期</index>遇聖僧</paragraph>
                    <paragraph align="center">
                        <annotation type="원주">
                            <noteContent>二十五</noteContent>
                        </annotation> 是歲<index type="지명">吳郡</index>
                        <index type="이름">朱靈期</index>者, 自<index type="국명">高麗</index>還. 舶爲風携至一洲, 洲有山因意登之十餘里, 聞午梵知有寺.</paragraph>
                </content>
            </text>
        </level3>
    </level2>
