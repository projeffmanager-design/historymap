                </biblioData>
            </front>
            <text>
                <content>
                    <paragraph align="center">○ <index type="이름">眞宗</index>, <index type="지명">延慶</index>
                        <index type="이름">法智講師</index>
                    </paragraph>
                    <paragraph align="center">
                        <annotation type="원주">
                            <noteContent>二十四 戊辰</noteContent>
                        </annotation>
                        <index type="이름">四明</index>
                        <index type="지명">延慶</index>
                        <index type="이름">法智</index>卒 …… 二十從本郡<index type="이름">寶雲</index>
                        <index type="이름">(義)通</index>師, 傳天台敎觀.</paragraph>
                </content>
            </text>
