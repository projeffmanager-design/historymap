#!/bin/bash

# 어느 단계든 실패하면 즉시 종료하여 성공 메시지를 출력하지 않습니다.
set -euo pipefail

# 커밋 메시지를 인수로 받습니다.
commit_message="$1"

# 인수가 없으면 기본 메시지를 사용합니다.
if [ -z "$commit_message" ]; then
  echo "커밋 메시지를 입력하세요. (예: sync 동기화1)"
  exit 1
fi

# Git 명령어를 실행합니다.
git add .
git commit -m "$commit_message"
git push origin main --force

echo "GitHub에 강제 동기화 완료: $commit_message"
