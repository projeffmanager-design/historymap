    /* ------------------- 지역명 텍스트 마커 CSS 추가 ------------------- */
        .location-label-marker {
    font-size: var(--label-font-size, 15px);
    font-weight: bold;
    color: #ffffff;
    text-shadow: -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000, 0px 0px 2px #000;
