<script>
// 🚀 [스마트 캐시 관리] 데이터 구조 변경 시에만 IndexedDB 삭제
(function() {
    const CONFIG = {
        APP_VERSION: '3.7.2',           // [v3.7.2] countries DB 복원 후 localStorage 캐시 강제 무효화
        DATA_SCHEMA_VERSION: '2.1.1'    // tile_30_120: Tsushima data[]→features[] 이동 — 캐시 강제 갱신
    };
    // 세션 캐시에서 schema version 을 참조할 수 있도록 전역 노출
    window._APP_SCHEMA_VERSION = CONFIG.DATA_SCHEMA_VERSION;
    window._APP_VERSION        = CONFIG.APP_VERSION;

    // 로딩 화면 우하단 버전 표기 — 가장 먼저 실행 (리다이렉트 전에도 보여야 함)
    // (DOM이 아직 파싱 중일 수 있으므로 HTML에도 하드코딩, 여기서는 DOMContentLoaded 후 재설정)
    const _setVersionLabels = () => {
        const lvEl = document.getElementById('loading-screen-version-text');
        if (lvEl) lvEl.textContent = CONFIG.APP_VERSION;
        const hvEl = document.getElementById('hamburger-version-label');
        if (hvEl) hvEl.textContent = 'v' + CONFIG.APP_VERSION;
    };
    const _lvEl = document.getElementById('loading-screen-version-text');
    if (_lvEl) {
        _setVersionLabels();
    } else {
        document.addEventListener('DOMContentLoaded', _setVersionLabels);
    }

    const storedAppVersion = localStorage.getItem('app_version');
    const storedSchemaVersion = localStorage.getItem('data_schema_version');
    
    // 1️⃣ 데이터 구조가 변경된 경우에만 IndexedDB + localStorage 데이터 캐시 삭제
    if (storedSchemaVersion !== CONFIG.DATA_SCHEMA_VERSION) {
        console.log(`📦 데이터 구조 변경 감지: ${storedSchemaVersion || '없음'} → ${CONFIG.DATA_SCHEMA_VERSION}`);
        console.log('📦 IndexedDB + countries 캐시 초기화 중...');
        
        // IndexedDB 전체 삭제 (castles, territories 등)
        if (window.indexedDB) {
            indexedDB.databases().then(dbs => {
                dbs.forEach(db => {
                    console.log(`🗑️ IndexedDB 삭제: ${db.name}`);
                    indexedDB.deleteDatabase(db.name);
                });
            }).catch(e => console.warn('IndexedDB 클리어 실패:', e));
        }
        
        // countries localStorage 캐시도 함께 삭제 (색상 불일치 방지)
        localStorage.removeItem('countries_cache');
        localStorage.removeItem('countries_cache_time');
        localStorage.removeItem('countries_cache_version');
        
        localStorage.setItem('data_schema_version', CONFIG.DATA_SCHEMA_VERSION);
    } else {
        console.log(`♻️ 기존 캐시 데이터 사용 가능 (스키마 버전: ${CONFIG.DATA_SCHEMA_VERSION})`);
    }
    
    // 2️⃣ 앱 버전이 변경된 경우 (UI/로직 수정)
    if (storedAppVersion !== CONFIG.APP_VERSION) {
        console.log(`🔄 앱 버전 업데이트: ${storedAppVersion || '없음'} → ${CONFIG.APP_VERSION}`);
        
        // Service Worker 캐시만 클리어 (HTML/CSS/JS 최신화)
        if ('caches' in window) {
            caches.keys().then(names => {
                names.forEach(name => {
                    console.log(`🗑️ 캐시 삭제: ${name}`);
                    caches.delete(name);
                });
            });
        }
        
        localStorage.setItem('app_version', CONFIG.APP_VERSION);
        
        // 강제 리로드 (캐시 무시)
        if (!window.location.hash.includes('reloaded')) {
            console.log('🔄 강제 리로드 실행 (데이터는 보존)...');
            // 🚩 [추가] sessionStorage 토큰을 리로드 후 복원하기 위해 임시 백업
            const _sToken = sessionStorage.getItem('token');
            if (_sToken) localStorage.setItem('_session_token_backup', _sToken);
            window.location.href = window.location.pathname + '?v=' + CONFIG.APP_VERSION + '&t=' + Date.now() + '#reloaded';
            return;
        }
        // 🚩 [추가] 리로드 후 sessionStorage 토큰 복원
        const _backupToken = localStorage.getItem('_session_token_backup');
        if (_backupToken && !sessionStorage.getItem('token')) {
            sessionStorage.setItem('token', _backupToken);
            localStorage.removeItem('_session_token_backup');
        }
    }
    
    console.log(`✅ 버전 확인 완료: 앱 ${CONFIG.APP_VERSION} / 데이터 ${CONFIG.DATA_SCHEMA_VERSION}`);
})();
// (removed duplicate/conflicting menu toggle logic)
</script>
